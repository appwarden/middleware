{
  "name": "@appwarden/middleware",
  "version": "3.14.0",
  "description": "Instantly disable all user interaction with your app deployed on Cloudflare or Vercel",
  "type": "module",
  "license": "MIT",
  "author": "Appwarden <support@appwarden.io>",
  "homepage": "https://appwarden.io/docs",
  "bugs": {
    "url": "https://github.com/appwarden/middleware/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/appwarden/middleware.git"
  },
  "keywords": [
    "appwarden",
    "nextjs",
    "remixjs",
    "cloudflare",
    "web3",
    "monitoring"
  ],
  "main": "./index.js",
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "default": "./index.js"
    },
    "./vercel": {
      "types": "./vercel.d.ts",
      "default": "./vercel.js"
    },
    "./cloudflare": {
      "types": "./cloudflare.d.ts",
      "default": "./cloudflare.js"
    },
    "./cloudflare/astro": {
      "types": "./cloudflare/astro.d.ts",
      "default": "./cloudflare/astro.js"
    },
    "./cloudflare/react-router": {
      "types": "./cloudflare/react-router.d.ts",
      "default": "./cloudflare/react-router.js"
    },
    "./cloudflare/tanstack-start": {
      "types": "./cloudflare/tanstack-start.d.ts",
      "default": "./cloudflare/tanstack-start.js"
    },
    "./cloudflare/nextjs": {
      "types": "./cloudflare/nextjs.d.ts",
      "default": "./cloudflare/nextjs.js"
    }
  },
  "packageManager": "pnpm@10.4.1",
  "engines": {
    "node": ">=22.14.0"
  },
  "scripts": {
    "prepare": "node scripts/prepare-semantic-release.cjs && husky",
    "dev": "node scripts/dev-mode-package.cjs && pnpm build --watch",
    "dev:exit": "node scripts/exit-dev-mode-package.cjs",
    "deploy:staging": "pnpm build && wrangler deploy -e staging",
    "release": "NODE_ENV=production pnpm build && node scripts/prepare-package.cjs && semantic-release",
    "build": "tsup",
    "check:types": "wrangler types && tsc --noEmit",
    "check:prettier": "prettier --check .",
    "check:ci": "pnpm check:types && pnpm check:prettier && pnpm build",
    "test": "vitest --run",
    "test:e2e": "playwright test",
    "test:vercel": "vitest --run -c vitest.node.config.ts",
    "test:coverage": "vitest --coverage",
    "coverage:badge": "node scripts/generate-coverage-badge.cjs",
    "sbom:generate": "cdxgen -o sbom.json -t js --spec-version 1.6 . && cdxgen -o sbom.xml -t js --spec-version 1.6 --output-format xml .",
    "prepack": "pnpm build",
    "commitlint": "commitlint --edit"
  },
  "dependencies": {
    "@upstash/redis": "^1.37.0",
    "@vercel/edge-config": "^1.4.3",
    "zod": "^3.25.76"
  },
  "peerDependencies": {
    "@astrojs/cloudflare": ">=11.0.0",
    "@opennextjs/cloudflare": ">=1.16.6",
    "@tanstack/start": "^1.120.20",
    "@vercel/functions": ">=1.0.0",
    "astro": ">=4.0.0",
    "next": ">=14"
  },
  "peerDependenciesMeta": {
    "astro": {
      "optional": true
    },
    "@astrojs/cloudflare": {
      "optional": true
    },
    "next": {
      "optional": true
    },
    "@opennextjs/cloudflare": {
      "optional": true
    },
    "@tanstack/start": {
      "optional": true
    },
    "@vercel/functions": {
      "optional": true
    }
  },
  "devDependencies": {
    "@amanda-mitchell/semantic-release-npm-multiple": "^3.17.0",
    "@cloudflare/vitest-pool-workers": "^0.14.7",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@cyclonedx/cdxgen": "^12.2.0",
    "@playwright/test": "^1.59.1",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/npm": "^13.1.5",
    "@types/node": "^25.6.0",
    "@vercel/functions": "^3.4.3",
    "@vitest/coverage-istanbul": "^4.1.4",
    "cheerio": "^1.2.0",
    "dotenv": "^17.4.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "prettier-plugin-organize-imports": "^4.3.0",
    "semantic-release": "^25.0.3",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.4",
    "wrangler": "^4.83.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "pnpm": {
    "overrides": {
      "@isaacs/brace-expansion@<=5.0.0": ">=5.0.1",
      "@opennextjs/cloudflare@<1.17.1": ">=1.17.1",
      "@smithy/config-resolver@<4.4.0": ">=4.4.0",
      "ajv@>=7.0.0-alpha.0 <8.18.0": ">=8.18.0",
      "body-parser@>=2.2.0 <2.2.1": ">=2.2.1",
      "cookie@<0.7.0": ">=0.7.0",
      "devalue@<5.6.4": ">=5.6.4",
      "dompurify@<=3.3.1": ">=3.3.2",
      "esbuild@<=0.24.2": ">=0.25.0",
      "fast-xml-parser@5.3.4": "5.5.10",
      "flatted@<3.4.2": ">=3.4.2",
      "h3@<1.15.6": ">=1.15.6",
      "h3@>=2.0.0 <=2.0.1-rc.14": ">=2.0.1-rc.15",
      "handlebars@4.7.8": "4.7.9",
      "js-yaml@<3.14.2": ">=3.14.2",
      "jws@=4.0.0": ">=4.0.1",
      "lodash@>=4.0.0 <=4.17.23": ">=4.18.1",
      "lodash-es@>=4.0.0 <=4.17.23": ">=4.18.1",
      "mermaid@<10.9.5": ">=10.9.5",
      "minimatch@<10.2.1": ">=10.2.3",
      "next@>=10.0.0 <16.1.7": ">=16.1.7",
      "npm@<=11.8.0": ">=11.9.0",
      "path-to-regexp@>=4.0.0 <6.3.0": ">=6.3.0",
      "picomatch@<4.0.4": ">=4.0.4",
      "qs@>=6.7.0 <=6.14.1": ">=6.14.2",
      "rollup@>=4.0.0 <4.59.0": ">=4.59.0",
      "serialize-javascript@<=7.0.2": ">=7.0.3",
      "svgo@=4.0.0": ">=4.0.1",
      "tar@<=7.5.10": ">=7.5.11",
      "undici@<7.24.0": ">=7.24.0",
      "wrangler@>=4.0.0 <4.59.1": ">=4.59.1",
      "@tanstack/start-server-core@1.163.2>h3-v2": "npm:h3@2.0.1-rc.16",
      "h3@>=2.0.0-beta.0 <=2.0.1-rc.16": ">=2.0.1-rc.17",
      "h3@>=2.0.0-beta.4 <2.0.1-rc.18": ">=2.0.1-rc.18",
      "h3@>=2.0.1-alpha.0 <=2.0.1-rc.16": ">=2.0.1-rc.17",
      "defu@<=6.1.4": ">=6.1.5",
      "vite@<=6.4.1": ">=6.4.2",
      "vite@>=7.0.0 <=7.3.1": ">=7.3.2",
      "vite@>=7.1.0 <=7.3.1": ">=7.3.2",
      "vite@>=6.0.0 <=6.4.1": ">=6.4.2",
      "next@>=16.0.0-beta.0 <16.2.3": ">=16.2.3",
      "follow-redirects@<=1.15.11": ">=1.16.0"
    }
  },
  "sideEffects": false
}
