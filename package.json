{
  "name": "@appwarden/middleware",
  "version": "3.16.4",
  "description": "Instantly disable all user interaction with your app deployed on Cloudflare or Vercel",
  "type": "module",
  "license": "MIT",
  "author": "Appwarden <support@appwarden.io>",
  "homepage": "https://appwarden.io/docs",
  "bugs": {
    "url": "https://github.com/appwarden/middleware/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/appwarden/middleware.git"
  },
  "keywords": [
    "appwarden",
    "nextjs",
    "remixjs",
    "cloudflare",
    "web3",
    "monitoring",
    "cli",
    "tanstack-intent"
  ],
  "main": "./index.js",
  "types": "./index.d.ts",
  "bin": {
    "appwarden-link": "./scripts/appwarden-link.cjs"
  },
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "default": "./index.js"
    },
    "./vercel": {
      "types": "./vercel.d.ts",
      "default": "./vercel.js"
    },
    "./cloudflare": {
      "types": "./cloudflare.d.ts",
      "default": "./cloudflare.js"
    },
    "./cloudflare/astro": {
      "types": "./cloudflare/astro.d.ts",
      "default": "./cloudflare/astro.js"
    },
    "./cloudflare/react-router": {
      "types": "./cloudflare/react-router.d.ts",
      "default": "./cloudflare/react-router.js"
    },
    "./cloudflare/tanstack-start": {
      "types": "./cloudflare/tanstack-start.d.ts",
      "default": "./cloudflare/tanstack-start.js"
    },
    "./cloudflare/nextjs": {
      "types": "./cloudflare/nextjs.d.ts",
      "default": "./cloudflare/nextjs.js"
    }
  },
  "packageManager": "pnpm@11.7.0+sha512.19cc852c120c7125760f2443ee6be0ca5b40f9f50598de1a09a1f177503e010e57c23c77646e01e761de59bf874fb22a3398c33ab9691fc13eb946b6f0f4d620",
  "engines": {
    "node": ">=22.14.0"
  },
  "scripts": {
    "prepare": "node scripts/prepare-semantic-release.cjs && husky",
    "dev": "node scripts/dev-mode-package.cjs && pnpm build --watch",
    "dev:exit": "node scripts/exit-dev-mode-package.cjs",
    "deploy:staging": "pnpm build && wrangler deploy -e staging",
    "release": "NODE_ENV=production pnpm build && node scripts/prepare-package.cjs && semantic-release",
    "build": "tsup",
    "check:types": "wrangler types && tsc --noEmit",
    "check:prettier": "prettier --check .",
    "check:ci": "pnpm check:types && pnpm check:prettier && pnpm build",
    "test": "vitest --run",
    "test:e2e": "playwright test",
    "test:vercel": "vitest --run -c vitest.node.config.ts",
    "test:coverage": "vitest --coverage",
    "coverage:badge": "node scripts/generate-coverage-badge.cjs",
    "sbom:generate": "cdxgen -o sbom.json -t js --spec-version 1.6 . && cdxgen -o sbom.xml -t js --spec-version 1.6 --output-format xml .",
    "prepack": "pnpm build",
    "commitlint": "commitlint --edit",
    "intent:scaffold": "intent scaffold",
    "intent:validate": "intent validate",
    "intent:stale": "intent stale",
    "intent:setup-ci": "intent setup-github-actions"
  },
  "dependencies": {
    "@upstash/redis": "^1.38.0",
    "@vercel/edge-config": "^1.4.3",
    "acorn": "^8.16.0",
    "zod": "^3.25.76"
  },
  "peerDependencies": {
    "@astrojs/cloudflare": ">=11.0.0",
    "@opennextjs/cloudflare": ">=1.16.6",
    "@tanstack/start": "^1.120.20",
    "@vercel/functions": ">=1.0.0",
    "astro": ">=4.0.0",
    "next": ">=14"
  },
  "peerDependenciesMeta": {
    "astro": {
      "optional": true
    },
    "@astrojs/cloudflare": {
      "optional": true
    },
    "next": {
      "optional": true
    },
    "@opennextjs/cloudflare": {
      "optional": true
    },
    "@tanstack/start": {
      "optional": true
    },
    "@vercel/functions": {
      "optional": true
    }
  },
  "devDependencies": {
    "@amanda-mitchell/semantic-release-npm-multiple": "^3.17.0",
    "@astrojs/cloudflare": "^13.6.0",
    "@cloudflare/vitest-pool-workers": "^0.16.14",
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@cyclonedx/cdxgen": "^12.5.0",
    "@opennextjs/cloudflare": "^1.19.11",
    "@playwright/test": "^1.61.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.8",
    "@semantic-release/npm": "^13.1.5",
    "@tanstack/intent": "^0.3.2",
    "@tanstack/start": "^1.120.20",
    "@types/node": "^25.9.3",
    "@vercel/functions": "^3.6.1",
    "@vitest/coverage-istanbul": "^4.1.8",
    "astro": "^6.4.6",
    "cheerio": "^1.2.0",
    "dotenv": "^17.4.2",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "next": "^16.2.9",
    "postcss": "^8.5.15",
    "prettier": "^3.8.4",
    "prettier-plugin-organize-imports": "^4.3.0",
    "semantic-release": "^25.0.5",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.8",
    "wrangler": "^4.97.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "sideEffects": false
}
